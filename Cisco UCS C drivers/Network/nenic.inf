[Enic_63.25398]
Characteristics = 0x84
BusType         = 5
Port1FunctionNumber = 0
AddReg          = Interfaces.reg, enic.Reg, vmq.reg, ndkp.reg, encap.reg, nvgre.reg, vxlan.reg, VxlanPort.reg, encap_overhead.reg, Offload.reg, qos.reg, pollmode.reg
