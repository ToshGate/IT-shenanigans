[Enic.Service]
DisplayName     = %enic.service.name%
ServiceType     = 1 ;%SERVICE_KERNEL_DRIVER%
StartType       = 3 ;%SERVICE_DEMAND_START%
ErrorControl    = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary   = %13%\nenic.sys
LoadOrderGroup  = NDIS

[Enic.Service.25398]
DisplayName     = %enic.service.name%
ServiceType     = 1 ;%SERVICE_KERNEL_DRIVER%
StartType       = 3 ;%SERVICE_DEMAND_START%
ErrorControl    = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary   = %13%\nenic.sys
LoadOrderGroup  = NDIS
BootFlags       = 1

[Common.EventLog]
AddReg = Common.Addeventlog.Reg

[Common.Addeventlog.Reg]
HKR, , EventMessageFile, 0x00020000, "%%SystemRoot%%\System32\netevent.dll;%13%\nenic.sys"
HKR, , TypesSupported,   0x00010001, 7

[SourceDisksNames]
1 = %cisco.disk%, nenic.sys,,

[SourceDisksFiles]
nenic.sys = 1,,

[Copyfiles]
nenic.sys,,,2

[DestinationDirs]
Copyfiles      = 13,

